<?xml version="1.0" encoding="UTF-8"?>
<verification-metadata xmlns="https://schema.gradle.org/dependency-verification" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://schema.gradle.org/dependency-verification https://schema.gradle.org/dependency-verification/dependency-verification-1.3.xsd">
   <configuration>
      <verify-metadata>true</verify-metadata>
      <verify-signatures>false</verify-signatures>
      <trusted-artifacts>
         <trust group="org.hisp.dhis.mobile" name="designsystem"/>
         <trust group="org.jetbrains.intellij.deps.kotlinx"/>
         <trust file=".*-javadoc\.jar" regex="true"/>
         <trust file=".*-sources\.jar" regex="true"/>
         <trust file=".*\.module" regex="true"/>
         <trust file=".*\.pom" regex="true"/>
         <trust file="gradle-.*-src\.zip" regex="true"/>
         <trust group="com.android.tools.build" name="aapt2" regex="true"/>
         <trust group="org.hisp.dhis" name="android-core" version=".*" regex="true"/>
         <trust group="org.hisp.dhis" name="android-core" version=".*-SNAPSHOT" regex="true"/>
         <trust group="org.hisp.dhis.mobile" name=".*" version=".*-SNAPSHOT" regex="true"/>
      </trusted-artifacts>
   </configuration>
   <components>
   </components>
</verification-metadata>
